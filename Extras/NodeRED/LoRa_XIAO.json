    {
        "id": "8dcef9b38c01c367",
        "type": "function",
        "z": "951a1b4207d9f883",
        "g": "f2f40bdb9235544a",
        "name": "Seperate out devices",
        "func": "// --- Multi-sensor safe Function node with InfluxDB write ---\n\nlet payload = msg.payload;\n\nif (Buffer.isBuffer(payload)) {\n    payload = payload.toString('utf8');\n}\n\nif (typeof payload === \"string\") {\n    try {\n        payload = JSON.parse(payload);\n    } catch (err) {\n        node.error(\"Invalid JSON payload\", msg);\n        return null;\n    }\n}\n\nconst device = payload.value;\nif (!device) return null;\n\n// Fields to ignore (non-metric)\nconst ignore = [\"value\", \"snr\", \"pferror\", \"packetSize\", \"batt_status\"];\n\n// Valid measurement names: letters, numbers, underscores only\nconst validName = /^[a-zA-Z_][a-zA-Z0-9_]*$/;\n\n// Valid device names: same rules\nconst validDevice = /^[a-zA-Z0-9_-]+$/;\n\nif (!validDevice.test(device)) {\n    node.warn(`Skipping bad device name: ${device}`);\n    return null;\n}\n\nconst messages = [];\n\nfor (const [key, val] of Object.entries(payload)) {\n    if (ignore.includes(key)) continue;\n    if (!validName.test(key)) {\n        node.warn(`Skipping bad field name: ${key}`);\n        continue;\n    }\n\n    const numVal = parseFloat(val);\n    if (isNaN(numVal)) {\n        node.warn(`Skipping non-numeric value for ${key}: ${val}`);\n        continue;\n    }\n\n    // Message 1: to MQTT (existing behavior)\n    // Message 2: to InfluxDB HTTP write\n    messages.push([\n        {\n            topic: `LoRa_NodeRed/${device}/${key}`,\n            payload: val,\n            retain: true\n        },\n        {\n            payload: `${key},device=${device} value=${numVal}`,\n            headers: { \"Content-Type\": \"text/plain\" }\n        }\n    ]);\n}\n\n// Send all validated messages\nfor (const [mqttMsg, influxMsg] of messages) {\n    node.send([mqttMsg, influxMsg]);\n}\n\nreturn null;",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
