        "func": "const pct = parseFloat(msg.payload);\nif (isNaN(pct)) {\n    msg.payload = \"UNKNOWN\";\n} else if (pct <= 10) {\n    msg.payload = \"CRITICAL\";\n} else if (pct <= 20) {\n    msg.payload = \"WARNING\";\n} else {\n    msg.payload = \"OK\";\n}\nreturn msg;",
