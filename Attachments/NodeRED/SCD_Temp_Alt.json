    {
        "id": "2c5103da2e11c608",
        "type": "function",
        "z": "b7d254abc3d5f1ce",
        "g": "da2f71dceb86776b",
        "name": "Format Response for Display",
        "func": "const parts = msg.topic.split('/');\nconst device = parts[1] || 'unknown';\nconst field = parts[2] || 'unknown';\n\nconst shortName = device.replace('LoRa_XIAO_CO2_', 'XIAO ');\nconst val = parseFloat(msg.payload);\n\nlet display;\nif (field.startsWith('temp_offset')) {\n    const valF = parseFloat((val * 1.8).toFixed(2));\n    display = `${shortName} — ${field}: ${val}°C (${valF}°F)`;\n} else if (field.startsWith('altitude')) {\n    const valFt = Math.round(val * 3.28084);\n    display = `${shortName} — ${field}: ${val}m (${valFt}ft)`;\n} else {\n    display = `${shortName} — ${field}: ${val}`;\n}\n\nmsg.payload = display;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
