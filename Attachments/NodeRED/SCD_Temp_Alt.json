    {
        "id": "debe1e33821728f1",
        "type": "function",
        "z": "b7d254abc3d5f1ce",
        "g": "da2f71dceb86776b",
        "name": "Build Calibration Command",
        "func": "const action     = msg.payload;\nconst device     = flow.get('cal_device');\nconst tempF      = flow.get('cal_temp_f') || 0;\nconst altFt      = flow.get('cal_alt_ft') || 1344;\n\nif (!device) {\n    node.warn('No device selected');\n    return null;\n}\n\nlet command = { target: device };\n\nif (action === 'set_temp') {\n    // SCD41 offset is always positive - it always subtracts this from readings\n    // Convert °F difference to °C difference (divide by 1.8, NOT subtract 32)\n    const absF = Math.abs(parseFloat(tempF) || 0);\n    const tempC = parseFloat((absF / 1.8).toFixed(2));\n    command.temp_offset = tempC;\n    node.status({ fill:'blue', shape:'dot',\n        text: `Set temp offset ${absF}°F (${tempC}°C) → ${device}` });\n\n} else if (action === 'get_temp') {\n    command.get_temp_offset = true;\n    node.status({ fill:'blue', shape:'dot',\n        text: `Get temp offset ← ${device}` });\n\n} else if (action === 'set_alt') {\n    // Convert feet to meters\n    const altM = Math.round(altFt / 3.28084);\n    command.altitude = altM;\n    node.status({ fill:'blue', shape:'dot',\n        text: `Set altitude ${altFt}ft (${altM}m) → ${device}` });\n\n} else if (action === 'get_alt') {\n    command.get_altitude = true;\n    node.status({ fill:'blue', shape:'dot',\n        text: `Get altitude ← ${device}` });\n}\n\nmsg.payload = JSON.stringify({\n    message: JSON.stringify(command)\n});\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 630,
        "y": 3700,
        "wires": [
            [
                "61319f845ebb4dfb",
                "fd5c23278ae5d6cb"
            ]
        ]
