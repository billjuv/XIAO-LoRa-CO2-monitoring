    {
        "id": "fb6bfd22c26d56ca",
        "type": "function",
        "z": "b7d254abc3d5f1ce",
        "g": "d7ea949645f9512c",
        "name": "Watchdog Check",
        "func": "// ---- CHANGE DEVICE ID HERE ----\nconst DEVICE = \"LoRa_XIAO_CO2_1_D893A8D4DB1C\";\n// --------------------------------\n\nconst YELLOW_MS = 5  * 60 * 1000;  // 5 min\nconst RED_MS    = 10 * 60 * 1000;  // 10 min\n\nlet lastSeen = flow.get(`watchdog_last_seen.${DEVICE}`);\nlet now = Date.now();\n\nlet led, statusText;\n\nif (!lastSeen) {\n    // Never received any data this session\n    led = \"red\";\n    statusText = \"No data received\";\n} else {\n    let ageMs  = now - lastSeen;\n    let ageMin = Math.floor(ageMs / 60000);\n    let ageSec = Math.floor((ageMs % 60000) / 1000);\n\n    if (ageMs < YELLOW_MS) {\n        led = \"green\";\n        statusText = ageMin > 0\n            ? `Last seen: ${ageMin} min ago`\n            : `Last seen: < 1 min ago`;\n\n \n    } else if (ageMs < RED_MS) {\n        led = \"yellow\";\n        statusText = `STALE — ${ageMin} min ago`;\n    } else {\n        led = \"red\";\n        statusText = `OFFLINE — ${ageMin} min ago`;\n    }\n}\n\nreturn [\n    { payload: led        },   // output 1 — LED color\n    { payload: statusText }    // output 2 — status text\n];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 630,
        "y": 920,
        "wires": [
