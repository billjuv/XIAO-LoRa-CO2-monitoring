        "id": "65bac582d1fd7cdb",
        "type": "function",
        "z": "b7d254abc3d5f1ce",
        "g": "d7ea949645f9512c",
        "name": "Store Last Seen Timestamp",
        "func": "// ---- CHANGE DEVICE ID HERE ----\nconst DEVICE = \"LoRa_XIAO_CO2_1_D893A8D4DB1C\";\n// --------------------------------\n\nflow.set(`watchdog_last_seen.${DEVICE}`, Date.now());\nreturn null;  // watchdog only — don't pass through",
