        "name": "MM:SS formatter",
        "func": "let totalSec = Number(msg.payload) || 0;\nlet minutes = Math.floor(totalSec / 60);\nlet seconds = totalSec % 60;\n\nmsg.payload = minutes > 0\n    ? `${minutes} min ${seconds.toString().padStart(2, '0')} sec`\n    : (totalSec === 0 ? \"--\" : `${seconds} sec`);\n\nreturn msg;",
