    {
        "id": "f5f7ec50a4e965ec",
        "type": "function",
        "z": "b7d254abc3d5f1ce",
        "g": "9a857536ec022484",
        "name": "Complete FRC — Build State & Outputs",
        "func": "// ---- CHANGE DEVICE ID HERE ----\nconst DEVICE = \"LoRa_XIAO_CO2_1_D893A8D4DB1C\";\n// --------------------------------\n\n// Read values\nlet target  = flow.get(`frc_pending_ppm.${DEVICE}`) || 425;\nlet actual  = flow.get(`frc_current_co2.${DEVICE}`) || 0;\nlet offset  = actual - target;\nlet now     = new Date().toLocaleString(\"en-US\");\n\n// Read existing MQTT state to preserve interval_days\n// (We'll receive this via the MQTT state subscriber — stored in flow context)\nlet existing = flow.get(`frc_state.${DEVICE}`) || {};\nlet intervalDays = existing.interval_days || 7;\n\n// Build updated state object\nlet state = {\n    device:           DEVICE,\n    last_frc:         now,\n    last_frc_actual:  actual,\n    last_frc_target:  target,\n    last_frc_offset:  offset,\n    interval_days:    intervalDays\n};\n\n// ---- Output 1: MQTT state update (retained) ----\nlet mqttMsg = {\n    topic:   `MushLoRa/NodeRed/frc/state/${DEVICE}`,\n    payload: JSON.stringify(state),\n    retain:  true,\n    qos:     1\n};\n\n// ---- Output 2: FRC command to OMG gateway ----\nlet omgMsg = {\n    topic:   \"MushLoRa/OMG_LORA_MOAPA/commands/MQTTtoLORA\",\n    payload: JSON.stringify({\n        message: JSON.stringify({ target: DEVICE, frc: target })\n    })\n};\n\n// ---- Output 3: Dashboard immediate updates (prior reading, corrected to, offset) ----\n// Bundle all three in one pass — downstream function will split\nlet dashMsg = {\n    payload: {\n        prior:  actual,\n        target: target,\n        offset: offset,\n        now:    now\n    }\n};\n\nreturn [ mqttMsg, omgMsg, dashMsg ];",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
