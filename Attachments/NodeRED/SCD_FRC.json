    {
        "id": "a1e874d2facb3e24",
        "type": "function",
        "z": "b7d254abc3d5f1ce",
        "g": "9a857536ec022484",
        "name": "Parse State & Calc Due",
        "func": "// ---- CHANGE DEVICE ID HERE ----\nconst DEVICE = \"LoRa_XIAO_CO2_1_D893A8D4DB1C\";\n// --------------------------------\n\n// Parse payload (may arrive as object or JSON string)\nlet state = (typeof msg.payload === \"string\")\n    ? JSON.parse(msg.payload)\n    : msg.payload;\n\n// Store in flow context so Complete FRC can read interval_days\nflow.set(`frc_state.${DEVICE}`, state);\n\nlet prior       = state.last_frc_actual  ?? \"—\";\nlet offset      = state.last_frc_offset  ?? \"—\";\nlet timestamp   = state.last_frc         ?? \"—\";\nlet intervalDays = state.interval_days   ?? 7;\n\n// ---- Calculate days until next recal ----\nlet daysUntilDue;\nlet led = \"green\";\n\nif (timestamp && timestamp !== \"—\") {\n    let lastDate = new Date(timestamp);\n    if (!isNaN(lastDate.getTime())) {\n        let diffDays = (Date.now() - lastDate.getTime()) / (1000 * 60 * 60 * 24);\n        daysUntilDue = Math.round(intervalDays - diffDays);\n\n        if (daysUntilDue <= 0 && daysUntilDue > -3) {\n            led = \"yellow\";\n        } else if (daysUntilDue <= -3) {\n            led = \"red\";\n        } else {\n            led = \"green\";\n        }\n    }\n}\n\nif (daysUntilDue === undefined || isNaN(daysUntilDue)) {\n    daysUntilDue = \"—\";\n}\n\nreturn [\n    { payload: timestamp },   // output 1 - Last FRC Date/Time\n    { payload: daysUntilDue },  // output 2 - Days Until Next Recal\n    { payload: led }    // output 3 - LED color\n];",
