    {
        "id": "af561cca4254419d",
        "type": "mqtt in",
        "z": "b7d254abc3d5f1ce",
        "g": "9a857536ec022484",
        "name": "FRC State — XIAO1 [CHANGE TOPIC]",
        "topic": "MushLoRa/NodeRed/frc/state/LoRa_XIAO_CO2_1_D893A8D4DB1C",
        "qos": "1",
