                "86d2667dc15772d0",
                "7df307a16360ecaa"
            ],
            [
                "eb6c77ba87cd5805",
                "f12fcdfd7d603649"
            ]
        ],
        "outputLabels": [
            "LED color",
            "Status text"
        ]
    },
