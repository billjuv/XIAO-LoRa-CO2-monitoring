    {
        "id": "14ea3791b957208a",
        "type": "function",
        "z": "b7d254abc3d5f1ce",
        "g": "9a857536ec022484",
        "name": "Save Interval to MQTT State",
        "func": "// ---- CHANGE DEVICE ID HERE ----\nconst DEVICE = \"LoRa_XIAO_CO2_1_D893A8D4DB1C\";\n// --------------------------------\n\nlet intervalDays = Number(msg.payload);\nif (isNaN(intervalDays) || intervalDays <= 0) return null;\n\n// Read current retained state so we don't overwrite other fields\nlet existing = flow.get(`frc_state.${DEVICE}`) || {};\n\n// Update interval_days only\nexisting.interval_days = intervalDays;\nexisting.device = DEVICE;  // ensure device field is present\n\n// Publish merged state back as retained\nmsg.topic = `MushLoRa/NodeRed/frc/state/${DEVICE}`;\nmsg.payload = JSON.stringify(existing);\nmsg.retain  = true;\nmsg.qos     = 1;\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
