    {
        "id": "5d37d190548c88a4",
        "type": "function",
        "z": "b7d254abc3d5f1ce",
        "g": "9a857536ec022484",
        "name": "Check Abort / Gate",
        "func": "// ---- CHANGE DEVICE ID HERE ----\nconst DEVICE = \"LoRa_XIAO_CO2_1_D893A8D4DB1C\";\n// --------------------------------\n\n// Only fires when countdown reaches 0 (natural finish or abort)\nif (msg.payload !== 0) return null;\n\nlet aborted = flow.get(`frc_abort.${DEVICE}`) || false;\nflow.set(`frc_abort.${DEVICE}`, false);  // clear flag\n\nif (aborted) {\n    node.status({ fill: \"red\", shape: \"dot\", text: \"Aborted\" });\n    return null;  // block — do nothing on abort\n}\n\nnode.status({ fill: \"green\", shape: \"dot\", text: \"Completing FRC...\" });\nreturn msg;  // pass through to FRC completion logic",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
