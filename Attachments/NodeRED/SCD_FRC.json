    {
        "id": "bdc0ca343222c81b",
        "type": "inject",
        "z": "b7d254abc3d5f1ce",
        "g": "d7ea949645f9512c",
        "name": "Check every 60 sec",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "60",
        "crontab": "",
        "once": true,
        "onceDelay": 5,
        "topic": "",
        "payload": "1",
        "payloadType": "num",
        "x": 400,
